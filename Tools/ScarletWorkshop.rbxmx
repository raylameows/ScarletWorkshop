				<Item class="ModuleScript" referent="RBX96D309D1BA6743E4A3BDB1435C9D3D6B">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Create = require(`./Create`)

return function(class: Create.Class)
	return function(defaults: Create.Properties)
		return function(properties: Create.Properties)
			for k, v in (defaults) do
				if properties[k] then 
					if k == `Children` then
						for _, child in (v) do
							table.insert(properties.Children, child)
						end
					end
					
					continue 
				end
				properties[k] = v
			end
			
			return Create (class) (properties)
		end
	end
end]]></ProtectedString>

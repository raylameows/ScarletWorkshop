			</Properties>
			<Item class="ModuleScript" referent="RBXCAE9AB7D4C9B42FAAB6A85E6572A36CF">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local EncodingService = game:GetService("EncodingService")
local HttpService = game:GetService("HttpService")
local ScriptEditorService = game:GetService("ScriptEditorService")

local Shared = require(`./Shared`)
local Instances = require(`./Instances`)
local FeatureCheck = require(`../Util/FeatureCheck`)
local NodeTreeVisualizer = require(`../Util/NodeTreeVisualizer`)

local Write = {}
local RootNode: Shared.Node?
local RootObject: Instance?

local function WriteValue(value: any, valueType: string, propOrAtt: string?)
	local valueType = valueType or typeof(value)
	local call = Write[valueType]
	if not call then
		warn(`Type {valueType} of {propOrAtt and `{propOrAtt} ` or ``}{value} cannot be serialized`)
		return
	end

	return call(value)
end

local function GetIndex(object: Instance)
	local index = 1
	for _, child in (object.Parent:GetChildren()) do
		if child == object then
			return index
		elseif Instances[child.ClassName] ~= nil then
			index += 1
		end
	end

	return index
end

function Write.string(input: string)
	return input
end

function Write.number(number: number)
	return number
end

function Write.boolean(bool: boolean)
	return bool
end

function Write.Color3(color: Color3)
	return {color.R, color.G, color.B}
end

function Write.Vector3(vector: Vector3)
	return {vector.X, vector.Y, vector.Z}
end

function Write.CFrame(cf: CFrame)
	return {cf:GetComponents()}
end

function Write.UDim2(udim: UDim2)
	return {
		udim.X.Scale, udim.X.Offset,
		udim.Y.Scale, udim.Y.Offset
	}
end

function Write.EnumItem(enumItem: EnumItem)
	return tostring(enumItem)
end

function Write.BrickColor(color: BrickColor)
	return color.Number
end

function Write.NumberSequence(seq: NumberSequence)
	local keypoints = {}
	for _, k in (seq.Keypoints) do
		table.insert(keypoints, {
			Time = k.Time,
			Value = k.Value,
			Envelope = k.Envelope
		})
	end

	return keypoints
end

function Write.ColorSequence(seq: ColorSequence)
	local keypoints = {}
	for _, k in (seq.Keypoints) do
		table.insert(keypoints, {
			Time = k.Time,
			Color = Write.Color3(k.Value)
		})
	end

	return keypoints
end

function Write.NumberRange(range: NumberRange)
	return {range.Min, range.Max}
end

function Write.Rect(rect: Rect)
	return {
		rect.Min.X, rect.Min.Y,
		rect.Max.X, rect.Max.Y
	}
end

function Write.UDim(udim: UDim)
	return {udim.Scale, udim.Offset}
end

function Write.Vector2(vector: Vector2)
	return {vector.X, vector.Y}
end

function Write.InstanceReference(object: Instance?)
	if not object then return end
	
	local path = {}
	local current = object
	while current ~= RootObject do
		local index = GetIndex(current)
		if index then
			table.insert(path, index)
		end
		
		current = current.Parent
	end
	
	for i = 1, math.floor(#path / 2) do
		path[i], path[#path - i + 1] = path[#path - i + 1], path[i]
	end
	
	RootNode.Config.Expensives += 1
	return table.concat(path, `.`)
end

function Write.Instance(object: Instance, direct: boolean): Shared.Node
	if not Instances[object.ClassName] then
		warn(`Unknown instance {object.Name} of class {object.ClassName} will not be serialized`)
		return
	end
	
	local node: Shared.Node = {
		Class = object.ClassName,
		Properties = {},
		Attributes = {},
		Children = {}
	}
	if direct then
		RootNode = node
		RootNode.Config = {
			Expensives = 0,
		}
	end
	
	local availableProperties = Instances[object.ClassName]
	for _, propertyData in (availableProperties) do
		local property, propertyType, default = unpack(propertyData)
		if object[property] == default then continue end
		node.Properties[property] = WriteValue(object[property], propertyType, `property`)
	end
	
	for attribute, value in (object:GetAttributes()) do
		if attribute:sub(1, 3) == `RBX` then continue end
		node.Attributes[attribute] = WriteValue(value, nil, `attribute`)
	end
	
	for _, child in (object:GetChildren()) do
		local childNode = Write.Instance(child)
		if not childNode then continue end
		table.insert(node.Children, childNode)
	end
	
	return node
end

function Write.Map(map: Instance)
	RootObject = map:Clone()
	local nodeTree = Write.Instance(RootObject, true)
	if FeatureCheck(`NodeTree`) then
		local previous = workspace:FindFirstChild(`Node Tree`)
		if previous and previous:IsA(`ModuleScript`) then
			previous:Destroy()
		end
		
		local ms = Instance.new(`ModuleScript`)
		ScriptEditorService:UpdateSourceAsync(ms, function()
			return `return {NodeTreeVisualizer(nodeTree)}`
		end)
		ms.Name = `Node Tree`
		ms.Parent = workspace
		ScriptEditorService:OpenScriptDocumentAsync(ms)
	end
	
	nodeTree = HttpService:JSONEncode(RootNode)
	
	local nodeTreeBuffer = buffer.fromstring(nodeTree)
	local compressedNodeTree = EncodingService:Base64Encode(
		EncodingService:CompressBuffer(nodeTreeBuffer, Enum.CompressionAlgorithm.Zstd)
	)
	
	local compressedString = buffer.readstring(compressedNodeTree, 0, buffer.len(compressedNodeTree))
	if FeatureCheck(`Debug`) then
		print(`=== Compression Stats ===`)
		print(`Before Compression: {#nodeTree * 0.001}K`)
		print(`After Compression: {#compressedString * 0.001}K`)
	end
	
	RootNode = nil
	RootObject:Destroy()
	RootObject = nil
	return compressedString
end

return Write]]></ProtectedString>
					<string name="ScriptGuid">{7cc3b943-be94-d1b7-f077-981937f60cdb}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">Write</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX6A59C2924EF547A6886F66C6605CD53A">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local AssetService = game:GetService("AssetService")
local EncodingService = game:GetService("EncodingService")
local HttpService = game:GetService("HttpService")

local Shared = require(`./Shared`)
local Instances = require(`./Instances`)
local Traverse = require(`../Util/Traverse`)

local Read = {}
local RootNode: Shared.Node?

local function ReadValue(value: any, valueType: string, propOrAtt: string?)
	local valueType = valueType or typeof(value)
	local call = Read[valueType]
	if not call then
		warn(`Type {valueType} of {propOrAtt and `{propOrAtt} ` or ``}{value} cannot be read`)
		return
	end

	return call(value)
end

function Read.string(input: string)
	return input
end

function Read.number(number: number)
	return number
end

function Read.boolean(bool: boolean)
	return bool
end

function Read.Color3(color: {number})
	return Color3.new(unpack(color))
end

function Read.Vector3(vector: {number})
	return Vector3.new(unpack(vector))
end

function Read.CFrame(cf: {number})
	return CFrame.new(unpack(cf))
end

function Read.UDim2(udim: {number})
	return UDim2.new(unpack(udim))
end

function Read.EnumItem(enumItem: string)
	local enumName, enumType, enumItem = unpack(string.split(enumItem, `.`))
	if not enumName or not enumType or not enumItem or enumName ~= `Enum` then
		warn(`Invalid EnumItem string {enumItem}`)
		return
	end

	return Enum[enumType][enumItem]
end


function Read.BrickColor(color: number)
	return BrickColor.new(color)
end

function Read.NumberSequence(seq: {[number]: {[string]: any}})
	local keypoints = {}
	for _, k in (seq) do
		table.insert(keypoints, NumberSequenceKeypoint.new(k.Time, k.Value, k.Envelope))
	end

	return NumberSequence.new(keypoints)
end

function Read.ColorSequence(seq: {[number]: {[string]: any}})
	local keypoints = {}
	for _, k in (seq) do
		table.insert(keypoints, ColorSequenceKeypoint.new(k.Time, Read.Color3(k.Color)))
	end

	return ColorSequence.new(keypoints)
end

function Read.NumberRange(range: {number})
	return NumberRange.new(unpack(range))
end

function Read.Rect(rect: {number})
	local min = Vector2.new(rect[1], rect[2])
	local max = Vector2.new(rect[3], rect[4])
	return Rect.new(min, max)
end

function Read.UDim(udim: {number})
	return UDim.new(unpack(udim))
end

function Read.Vector2(vector)
	return Vector2.new(unpack(vector))
end

function Read.Mesh(id: string)
	local cache = Traverse(`ReplicatedStorage.Assets.MeshCache`)
	local mesh: MeshPart? = cache:FindFirstChild(id)
	local skipProperties = {MeshId = true}
	if mesh then
		mesh = mesh:Clone()
	else
		local success, err = pcall(function()
			mesh = AssetService:CreateMeshPartAsync(Content.fromUri(id))
		end)
		
		if success then
			mesh.Name = id
			mesh.Parent = cache
			mesh = mesh:Clone()
		else
			warn(`Mesh fetch error {err}`)
			mesh = Instance.new(`Part`)
			skipProperties.TextureID = true
		end
	end
	
	return mesh, skipProperties
end

function Read.InstanceReference(node: Shared.Node, property: string)
	if node == nil or node.Properties[property] == nil then return end
	
	local path = string.split(node.Properties[property], `.`)
	local current = RootNode
	for _, move in (path) do
		current = current.Children[tonumber(move)]
	end
	
	repeat task.wait() until current.Object
	node.Object[property] = current.Object
	return
end

function Read.Instance(node: Shared.Node, direct: boolean)
	if not Instances[node.Class] then
		warn(`Unknown node with name {node.Properties.Name} of class {node.Class} will not be read`)
		return
	end
	
	local object: Instance?
	local skipProperties: {[string]: boolean} = {}
	if node.Class == `MeshPart` and node.Properties.MeshId and node.Properties.MeshId ~= `` then
		object, skipProperties = Read.Mesh(node.Properties.MeshId)
	else
		object = Instance.new(node.Class)
	end
	
	local availableProperties = Instances[object.ClassName]
	for _, propertyData in (availableProperties) do
		local property, propertyType, default = unpack(propertyData)
		if skipProperties[property] then continue end
		
		if propertyType == `InstanceReference` then
			task.spawn(Read.InstanceReference, node, property)
		else
			object[property] = node.Properties[property] == nil and default or ReadValue(node.Properties[property], propertyType, `property`)
		end
	end
	
	for attribute, value in (node.Attributes) do
		object:SetAttribute(attribute, ReadValue(value, nil, `attribute`))
	end
	
	for _, childNode in (node.Children) do
		local child = Read.Instance(childNode)
		if not child then continue end
		child.Parent = object
	end
	
	node.Object = object
	return object
end

function Read.Map(code: string)
	local compressedNodeTree = buffer.fromstring(code)
	local nodeTreeBuffer = EncodingService:DecompressBuffer(
		EncodingService:Base64Decode(compressedNodeTree), Enum.CompressionAlgorithm.Zstd
	)
	
	local clearCode = buffer.readstring(nodeTreeBuffer, 0, buffer.len(nodeTreeBuffer))
	local nodeTree = HttpService:JSONDecode(clearCode)
	
	RootNode = nodeTree
	local map = Read.Instance(nodeTree)
	return map
end

return Read]]></ProtectedString>
					<string name="ScriptGuid">{9501ff80-411d-0c9b-8757-f0764378230f}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">Read</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXAC3F6F70A9374A489F4DE81F5F08712A">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Shared = {}

export type Node = {
	Class: string,
	Object: Instance?,
	Properties: {
		[string]: any
	},
	Attributes: {
		[string]: any
	},
	Children: {
		[number]: Node
	},
	Config: {
		[string]: any
	}?
}

return Shared]]></ProtectedString>

					<string name="Name">NodeTreeVisualizer</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX77A13F5E2C524DBD8E40675BC248105C">
